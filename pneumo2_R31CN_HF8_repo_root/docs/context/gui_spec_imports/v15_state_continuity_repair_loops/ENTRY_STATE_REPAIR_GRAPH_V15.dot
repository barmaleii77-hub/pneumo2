  RingSeamInvalid -> RingClean [label="Исправить сегменты"];
  RingClean -> RingExportStale [label="Изменить сегмент"];
  RingExportStale -> RingClean [label="Переэкспортировать"];
  RingClean -> SuiteFresh [label="Сформировать snapshot"];
  SuiteFresh -> SuiteStale [label="Ring/input drift"];
  SuiteStale -> RingClean [label="Вернуться в Редактор кольца"];
  SuiteFresh -> BaselineReady [label="Сформировать baseline"];
  BaselineReady -> BaselineMismatch [label="Source/hash drift"];
  BaselineMismatch -> BaselineReady [label="Сделать baseline активным"];
