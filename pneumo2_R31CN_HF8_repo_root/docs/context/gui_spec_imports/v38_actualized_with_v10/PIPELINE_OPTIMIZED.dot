SHELL -> RING [label="tree/search/selection sync"];
SHELL -> SUITE [label="tree/search/selection sync"];
SHELL -> BASE [label="tree/search/selection sync"];
SHELL -> OPT [label="tree/search/selection sync"];
SHELL -> AN [label="tree/search/selection sync"];
SHELL -> AM [label="tree/search/selection sync"];
SHELL -> DI [label="tree/search/selection sync"];
}