digraph G {
  rankdir=LR;
  graph [fontname="Arial", labelloc=t, fontsize=20, label="V19 current evidence-bound: Диагностика"];
  node [fontname="Arial", fontsize=10, style="rounded,filled", fillcolor=white];
  edge [fontname="Arial", fontsize=9, color="#555555"];
  subgraph cluster__evidence_bound_ {
    label="Текущее evidence-bound состояние"; color="#cccccc"; style="rounded";
    "TREE-WS-DIAGNOSTICS" [label="Диагностика", shape=tab, fillcolor="#134f5c"];
    "CUR-DI-LAUNCH" [label="Открыть GUI диагностики", shape=tab, fillcolor="#134f5c"];
    "CUR-DI-SEND-LAUNCH" [label="Открыть GUI отправки результатов", shape=tab, fillcolor="#134f5c"];
    "CUR-DI-ROUTE-SPLIT" [label="Диагностика и отправка архива конкурируют как первые шаги", shape=octagon, fillcolor="#990000"];
    "CUR-DI-BUNDLE-FRESHNESS" [label="Свежесть, путь и состав последнего bundle читаются не всегда на первом экране", shape=octagon, fillcolor="#990000"];
    "CUR-DI-RUNTIME-HIDDEN" [label="Helper runtime, selfcheck и provenance видны недостаточно рано", shape=octagon, fillcolor="#990000"];
  }
  "TREE-WS-DIAGNOSTICS" -> "CUR-DI-LAUNCH" [label="navigates / 1.00", color="#0b5394", penwidth=1, style=solid];
  "CUR-DI-LAUNCH" -> "CUR-DI-SEND-LAUNCH" [label="task_flow / 1.00", color="#0b5394", penwidth=1, style=solid];
  "CUR-DI-SEND-LAUNCH" -> "CUR-DI-ROUTE-SPLIT" [label="task_flow / 1.20", color="#0b5394", penwidth=1, style=solid];
  "CUR-DI-ROUTE-SPLIT" -> "CUR-DI-BUNDLE-FRESHNESS" [label="task_flow / 1.20", color="#0b5394", penwidth=1, style=solid];
  "CUR-DI-BUNDLE-FRESHNESS" -> "CUR-DI-RUNTIME-HIDDEN" [label="task_flow / 1.20", color="#0b5394", penwidth=1, style=solid];
}
