    "IN-TASK-VALIDATE" [label="Проверить входные данные", shape=ellipse, fillcolor="#cc0000"];
    "IN-TASK-SAVE" [label="Сохранить validated snapshot", shape=ellipse, fillcolor="#cc0000"];
    "IN-TASK-HANDOFF" [label="Передать validated snapshot дальше по pipeline", shape=ellipse, fillcolor="#cc0000"];
  }
  subgraph cluster__guards {
    label="Проверки и guards"; color="#cccccc"; style="rounded";
    "IN-CHECK-REQ" [label="Проверка обязательных полей и единиц измерения", shape=diamond, fillcolor="#e69138"];
    "IN-CHECK-GEOM" [label="Проверка геометрической согласованности", shape=diamond, fillcolor="#e69138"];
    "IN-CHECK-SPRING-VIS" [label="Проверка видимости выбора C1/C2 на угол", shape=diamond, fillcolor="#e69138"];
    "IN-CHECK-LEVELING-VIS" [label="Проверка видимости режима выравнивания и остатка", shape=diamond, fillcolor="#e69138"];
    "IN-CHECK-SYMMETRY-VIS" [label="Проверка видимости режима зеркальной симметрии", shape=diamond, fillcolor="#e69138"];
    "IN-CHECK-TWIN-SYNC" [label="Проверка двусторонней синхронизации с графическим двойником", shape=diamond, fillcolor="#e69138"];
  }
  subgraph cluster__ {
    label="Блокировки и запреты"; color="#cccccc"; style="rounded";
    "IN-BLOCK-REQ" [label="Не все обязательные входы заполнены", shape=octagon, fillcolor="#990000"];
    "IN-BLOCK-GEOM" [label="Геометрия противоречива или нарушает ограничения", shape=octagon, fillcolor="#990000"];
    "IN-BLOCK-TWIN" [label="Графический двойник не может быть построен честно", shape=octagon, fillcolor="#990000"];
    "IN-BLOCK-HANDOFF" [label="Нельзя передать дальше: snapshot не сохранён или не валиден", shape=octagon, fillcolor="#990000"];
  }
  subgraph cluster__ {
    label="Обратная связь и видимые состояния"; color="#cccccc"; style="rounded";
    "IN-FEEDBACK-C1C2" [label="На угол установлены две пружины: контур C1 и контур C2", shape=parallelogram, fillcolor="#38761d"];
    "IN-FEEDBACK-LEVELING" [label="Выравнивание кузова пружинами активно; показан метод и остаточная разница, миллиметры", shape=parallelogram, fillcolor="#38761d"];
    "IN-FEEDBACK-SYMMETRY" [label="Зеркальная симметрия лево/право включена и заблокирована", shape=parallelogram, fillcolor="#38761d"];
    "IN-FEEDBACK-TWIN" [label="Графический двойник обновлён по введённым данным", shape=parallelogram, fillcolor="#38761d"];
    "IN-FEEDBACK-VALID" [label="Validation summary виден на текущем экране", shape=parallelogram, fillcolor="#38761d"];
    "IN-FEEDBACK-SAVED" [label="Validated snapshot сохранён и готов к handoff", shape=parallelogram, fillcolor="#38761d"];
  }
  subgraph cluster__ {
