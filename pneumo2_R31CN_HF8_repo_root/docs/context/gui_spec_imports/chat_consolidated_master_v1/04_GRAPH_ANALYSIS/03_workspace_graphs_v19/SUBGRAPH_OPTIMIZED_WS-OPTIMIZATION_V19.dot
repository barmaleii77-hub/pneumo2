    "OPT-CHECK-CONTRACT" [label="Проверка полноты objective contract и hard gate", shape=diamond, fillcolor="#e69138"];
    "OPT-CHECK-MODE" [label="Проверка единственного активного режима", shape=diamond, fillcolor="#e69138"];
    "OPT-CHECK-RUN-ID" [label="Проверка identity problem hash / objective contract", shape=diamond, fillcolor="#e69138"];
    "OPT-CHECK-HISTORY" [label="Проверка совместимости historical run с текущим контрактом", shape=diamond, fillcolor="#e69138"];
  }
  subgraph cluster__ {
    label="Блокировки и запреты"; color="#cccccc"; style="rounded";
