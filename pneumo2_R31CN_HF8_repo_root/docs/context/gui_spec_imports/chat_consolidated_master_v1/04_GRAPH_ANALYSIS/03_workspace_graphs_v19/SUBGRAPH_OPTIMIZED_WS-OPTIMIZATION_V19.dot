    "OPT-FEEDBACK-CONTRACT" [label="Стек целей и жёсткое ограничение видны на одном уровне", shape=parallelogram, fillcolor="#38761d"];
    "OPT-FEEDBACK-STAGE" [label="Текущая стадия, live rows и elapsed budget видны на текущем экране", shape=parallelogram, fillcolor="#38761d"];
    "OPT-FEEDBACK-UNDERFILL" [label="Underfill, gate reasons и selected counts видны на текущем экране", shape=parallelogram, fillcolor="#38761d"];
