digraph "optimized_pipeline" {
  rankdir=LR;
  graph [fontsize=10, fontname="Arial"];
  node [shape=box, fontsize=10, fontname="Arial"];
  edge [fontsize=9, fontname="Arial"];
  "OPT-00" [label="OPT-00\nЗапуск или восстановление проекта", shape=oval];
  "OPT-01" [label="OPT-01\nПанель проекта", shape=box];
  "OPT-02" [label="OPT-02\nИсходные данные", shape=box];
  "OPT-03" [label="OPT-03\nРедактор кольца и сценариев", shape=box];
  "OPT-04" [label="OPT-04\nМатрица испытаний", shape=box];
  "OPT-05" [label="OPT-05\nБазовый прогон", shape=box];
  "OPT-06" [label="OPT-06\nЦентр оптимизации", shape=box];
  "OPT-07" [label="OPT-07\nМонитор выполнения", shape=box];
  "OPT-08" [label="OPT-08\nЦентр результатов", shape=box];
  "OPT-09" [label="OPT-09\nАналитика", shape=box];
  "OPT-10" [label="OPT-10\nАниматор", shape=box];
  "OPT-11" [label="OPT-11\nДиагностика", shape=box];
  "OPT-12" [label="OPT-12\nПараметры и инструменты", shape=box];
  "OPT-13" [label="OPT-13\nПравая панель свойств и помощи", shape=component];
  "OPT-14" [label="OPT-14\nЛевая панель навигации", shape=component];
  "OPT-15" [label="OPT-15\nВерхняя командная панель", shape=component];
  "OPT-16" [label="OPT-16\nНижняя строка состояния и прогресса", shape=component];
  "OPT-17" [label="OPT-17\nРешение пользователя после визуальной проверки", shape=oval];
  "OPT-18" [label="OPT-18\nПерсистентность и автосохранение", shape=box];
  "OPT-00" -> "OPT-18" [label="Запуск проекта"];
  "OPT-18" -> "OPT-01" [label="Проект открыт"];
  "OPT-01" -> "OPT-02" [label="Перейти к исходным данным"];
  "OPT-02" -> "OPT-13" [label="Навести курсор / нажать «?»"];
  "OPT-02" -> "OPT-17" [label="Изменить параметры"];
  "OPT-01" -> "OPT-03" [label="Перейти к сценариям"];
  "OPT-03" -> "OPT-17" [label="Редактировать сегмент"];
  "OPT-03" -> "OPT-04" [label="Подтвердить сценарий и добавить в испытания"];
  "OPT-04" -> "OPT-05" [label="Запустить базовый прогон"];
  "OPT-05" -> "OPT-07" [label="Расчёт выполняется"];
  "OPT-07" -> "OPT-08" [label="Расчёт завершён"];
  "OPT-08" -> "OPT-05" [label="Принять результат как baseline"];
  "OPT-01" -> "OPT-06" [label="Перейти к оптимизации"];
  "OPT-06" -> "OPT-07" [label="Запустить выбранный режим"];
  "OPT-07" -> "OPT-08" [label="Оптимизация идёт/завершена"];
  "OPT-08" -> "OPT-09" [label="Разобрать результат"];
  "OPT-09" -> "OPT-10" [label="Открыть пространственный просмотр"];
  "OPT-01" -> "OPT-11" [label="Нажать «Собрать диагностику»"];
  "OPT-11" -> "OPT-18" [label="Штатный выход/сбой"];
  "OPT-01" -> "OPT-12" [label="Открыть редкие настройки"];
  "OPT-15" -> "OPT-02" [label="Найти параметр через поиск команд"];
  "OPT-14" -> "OPT-03" [label="Выбрать сценарий/сегмент/тест в дереве"];
  "OPT-17" -> "OPT-02" [label="Исправить входы после предупреждения"];
  "OPT-17" -> "OPT-03" [label="Исправить сценарий после проверки превью"];
  "OPT-17" -> "OPT-06" [label="Повторить оптимизацию с изменённым objective contract"];
}
