digraph "optimized_element" {
  rankdir=LR;
  graph [splines=true, overlap=false];
  node [shape=box, style="rounded"];
  "SH-WS-SWITCHER" [label="Переключатель рабочего пространства\n[segmented_control]"];
  "SH-CMD-SEARCH" [label="Поиск команд\n[search_box]"];
  "SH-PRIMARY-ACTION" [label="Главная кнопка текущего шага\n[primary_button]"];
  "SH-DIAG-BUTTON" [label="Собрать диагностику\n[secondary_button]"];
  "SH-NAV-TREE" [label="Дерево навигации\n[tree_view]"];
  "SH-INSPECTOR-CONTENT" [label="Содержимое правой панели\n[scroll_container]"];
  "SH-STATUS-PROGRESS" [label="Нижний индикатор прогресса\n[progress_bar]"];
  "PJ-BTN-CONTINUE" [label="Продолжить работу\n[primary_button]"];
  "PJ-BTN-OPEN-INPUTS" [label="Открыть исходные данные\n[secondary_button]"];
  "PJ-BTN-OPEN-RING" [label="Открыть редактор кольца\n[secondary_button]"];
  "PJ-BTN-OPEN-OPT" [label="Открыть центр оптимизации\n[secondary_button]"];
  "ID-PARAM-TABLE" [label="Таблица параметров\n[data_grid]"];
  "ID-PREVIEW-CANVAS" [label="Графическое представление входных данных\n[canvas]"];
  "ID-BTN-AUTO-MIDSTROKE" [label="Автоподбор к середине хода\n[secondary_button]"];
  "RG-SEGMENT-LIST" [label="Список сегментов\n[list_view]"];
  "RG-PLAN-VIEW" [label="План кольца\n[canvas]"];
  "RG-SEAM-DIAGNOSTICS" [label="Диагностика замыкания\n[message_list]"];
  "RG-BTN-GENERATE-PREVIEW" [label="Сгенерировать предварительный просмотр\n[secondary_button]"];
  "RG-BTN-ADD-TO-SUITE" [label="Добавить в испытания\n[primary_button]"];
  "TS-TABLE" [label="Таблица испытаний\n[data_grid]"];
  "TS-BTN-VALIDATE" [label="Проверить набор испытаний\n[secondary_button]"];
  "TS-BTN-RUN-BASELINE" [label="Запустить базовый прогон\n[primary_button]"];
  "BL-BTN-RUN" [label="Запустить базовый прогон\n[primary_button]"];
  "BL-BTN-ACCEPT" [label="Принять результат как baseline\n[secondary_button]"];
  "BL-HISTORY-TABLE" [label="История baseline\n[data_grid]"];
  "OP-MODE-SELECT" [label="Выбор активного режима оптимизации\n[segmented_control]"];
  "OP-OBJECTIVE-STACK" [label="Редактор стека целей\n[list_editor]"];
  "OP-HARD-GATE" [label="Редактор жёсткого ограничения\n[form_card]"];
  "OP-STAGERUNNER-BLOCK" [label="Блок настроек StageRunner\n[scroll_form]"];
  "OP-DISTRIBUTED-BLOCK" [label="Блок distributed coordinator\n[scroll_form]"];
  "OP-BTN-LAUNCH" [label="Главная кнопка запуска оптимизации\n[primary_button]"];
  "MN-STAGE-HERO" [label="Hero текущей стадии\n[hero_panel]"];
  "MN-PROGRESS-BAR" [label="Главный индикатор прогресса\n[progress_bar]"];
  "MN-CURRENT-STAGE-TABLE" [label="Текущая стадия\n[data_grid]"];
  "MN-GATE-REASONS" [label="Причины gate и underfill\n[analysis_panel]"];
  "MN-BTN-STOP" [label="Остановить расчёт\n[danger_button]"];
  "RS-LEADERBOARD" [label="Лидерборд запусков\n[data_grid]"];
  "RS-COMPARE-CHART" [label="График сравнения baseline и выбранного run\n[chart]"];
  "RS-BTN-ACCEPT-BASELINE" [label="Принять как baseline\n[primary_button]"];
  "RS-BTN-OPEN-ANALYTICS" [label="Открыть аналитику\n[secondary_button]"];
  "RS-BTN-OPEN-ANIMATOR" [label="Открыть аниматор\n[secondary_button]"];
  "AN-MAIN-CHART" [label="Главный график\n[chart]"];
  "AN-EXPLANATION" [label="Пояснение результата\n[rich_text_panel]"];
  "AM-VIEWPORT" [label="3D viewport\n[viewport_3d]"];
  "AM-VIEWCUBE" [label="Навигационный куб\n[viewcube]"];
  "AM-TRUTH-BANNER" [label="Баннер достоверности\n[truth_banner]"];
  "AM-TIMELINE" [label="Таймлайн аниматора\n[timeline]"];
  "AM-DETACH" [label="Отстыковать аниматор\n[secondary_button]"];
  "DG-BTN-COLLECT" [label="Собрать диагностику\n[primary_button]"];
  "DG-CONTENTS" [label="Состав пакета диагностики\n[checklist_panel]"];
  "DG-HEALTH" [label="Состояние self-check\n[health_panel]"];
  "DG-LAST-BUNDLE" [label="Сведения о последнем архиве\n[summary_card]"];
  "ST-CATEGORY-LIST" [label="Список категорий параметров\n[list_view]"];
  "ST-FORM" [label="Форма выбранной категории\n[scroll_form]"];
  "PJ-BTN-CONTINUE" -> "SH-PRIMARY-ACTION" [label="Панель проекта определяет следующий шаг и пробрасывает его в глобальную главную кнопку."];
  "PJ-BTN-OPEN-INPUTS" -> "ID-PARAM-TABLE" [label="Перейти к исходным данным."];
  "ID-PARAM-TABLE" -> "ID-PREVIEW-CANVAS" [label="Выбрать параметр; графическое представление подсветит связанную геометрию."];
  "ID-BTN-AUTO-MIDSTROKE" -> "ID-PREVIEW-CANVAS" [label="Выполнить автоматический подбор и обновить графику."];
  "SH-INSPECTOR-CONTENT" -> "ID-PARAM-TABLE" [label="Изменить пределы, help и связи выбранного параметра."];
  "PJ-BTN-OPEN-RING" -> "RG-SEGMENT-LIST" [label="Перейти к редактированию сценария."];
  "RG-SEGMENT-LIST" -> "RG-PLAN-VIEW" [label="Выбрать сегмент; план кольца подсвечивает сегмент."];
  "RG-PLAN-VIEW" -> "RG-SEAM-DIAGNOSTICS" [label="После правки сегмента обновить диагностику шва."];
  "RG-BTN-GENERATE-PREVIEW" -> "RG-PLAN-VIEW" [label="Построить preview без добавления в suite."];
  "RG-BTN-ADD-TO-SUITE" -> "TS-TABLE" [label="Подтверждённо добавить сценарий в матрицу испытаний."];
  "TS-BTN-VALIDATE" -> "SH-INSPECTOR-CONTENT" [label="Вывести ошибки validation и связанные help-пояснения."];
  "TS-BTN-RUN-BASELINE" -> "BL-BTN-RUN" [label="Переход к baseline run."];
  "BL-BTN-RUN" -> "MN-STAGE-HERO" [label="Запустить baseline и открыть монитор выполнения."];
  "BL-HISTORY-TABLE" -> "RS-LEADERBOARD" [label="Просмотр принятых baseline в результатах."];
  "PJ-BTN-OPEN-OPT" -> "OP-MODE-SELECT" [label="Открыть solve-center."];
  "OP-MODE-SELECT" -> "OP-STAGERUNNER-BLOCK" [label="При выборе StageRunner показать только staged settings."];
  "OP-MODE-SELECT" -> "OP-DISTRIBUTED-BLOCK" [label="При выборе distributed coordinator показать только distributed settings."];
  "OP-OBJECTIVE-STACK" -> "SH-OBJECTIVE-CONTRACT" [label="Изменение objective stack обновляет глобальный контракт в верхней панели."];
  "OP-HARD-GATE" -> "SH-OBJECTIVE-CONTRACT" [label="Изменение hard gate обновляет глобальный контракт в верхней панели."];
  "OP-BTN-LAUNCH" -> "MN-STAGE-HERO" [label="Запустить оптимизацию и открыть монитор выполнения."];
  "MN-STAGE-HERO" -> "MN-CURRENT-STAGE-TABLE" [label="Hero связывает текущую стадию с живыми строками."];
  "MN-CURRENT-STAGE-TABLE" -> "MN-GATE-REASONS" [label="Недобор и gate reasons объясняются рядом со stage data."];
  "MN-BTN-STOP" -> "SH-STATUS-PROGRESS" [label="Остановить расчёт и обновить статус в нижней строке."];
  "MN-PROGRESS-BAR" -> "RS-LEADERBOARD" [label="После завершения перейти к результатам."];
  "RS-LEADERBOARD" -> "RS-COMPARE-CHART" [label="Выбор run обновляет график сравнения."];
  "RS-BTN-ACCEPT-BASELINE" -> "BL-HISTORY-TABLE" [label="Принять run как baseline и обновить историю."];
  "RS-BTN-OPEN-ANALYTICS" -> "AN-MAIN-CHART" [label="Открыть аналитику."];
  "RS-BTN-OPEN-ANIMATOR" -> "AM-VIEWPORT" [label="Открыть аниматор."];
  "AN-MAIN-CHART" -> "AN-EXPLANATION" [label="Выбранная аналитика раскрывает текстовое объяснение."];
  "AM-VIEWPORT" -> "AM-TRUTH-BANNER" [label="Любой просмотр всегда сопровождается truth-banner."];
  "AM-VIEWCUBE" -> "AM-VIEWPORT" [label="Перестроить вид сцены."];
  "AM-TIMELINE" -> "AM-VIEWPORT" [label="Изменение времени обновляет сцену."];
  "SH-DIAG-BUTTON" -> "DG-BTN-COLLECT" [label="Глобальный переход к диагностике."];
  "DG-BTN-COLLECT" -> "DG-LAST-BUNDLE" [label="Сборка архива обновляет сведения о последнем архиве."];
  "DG-HEALTH" -> "SH-INSPECTOR-CONTENT" [label="Детали self-check и ошибки можно открыть в правой панели."];
  "SH-CMD-SEARCH" -> "SH-NAV-TREE" [label="Поиск может вести в дерево, workspace или напрямую на элемент."];
  "ST-CATEGORY-LIST" -> "ST-FORM" [label="Выбрать категорию редких настроек."];
}