digraph "current_pipeline" {
  rankdir=LR;
  graph [fontsize=10, fontname="Arial"];
  node [shape=box, fontsize=10, fontname="Arial"];
  edge [fontsize=9, fontname="Arial"];
  "CUR-00" [label="CUR-00\nЗапуск приложения", shape=oval];
  "CUR-01" [label="CUR-01\nBootstrap рабочего пространства", shape=box];
  "CUR-02" [label="CUR-02\nГлавный экран", shape=box];
  "CUR-03" [label="CUR-03\nИсходные данные", shape=box];
  "CUR-04" [label="CUR-04\nРежимы и флаги", shape=box];
  "CUR-05" [label="CUR-05\nРедактор набора испытаний", shape=box];
  "CUR-06" [label="CUR-06\nГенератор сценариев", shape=box];
  "CUR-07" [label="CUR-07\nБазовый прогон", shape=box];
  "CUR-08" [label="CUR-08\nОптимизация на главном экране", shape=box];
  "CUR-09" [label="CUR-09\nСтраница Optimization", shape=box];
  "CUR-10" [label="CUR-10\nStageRunner", shape=box];
  "CUR-11" [label="CUR-11\ndistributed coordinator", shape=box];
  "CUR-12" [label="CUR-12\nМонитор прогресса", shape=box];
  "CUR-13" [label="CUR-13\nАнализ и сравнение", shape=box];
  "CUR-14" [label="CUR-14\n3D аниматор", shape=box];
  "CUR-15" [label="CUR-15\nДиагностика", shape=box];
  "CUR-16" [label="CUR-16\nСкрытые/исторические маршруты", shape=box];
  "CUR-17" [label="CUR-17\nРешение пользователя", shape=oval];
  "CUR-00" -> "CUR-01" [label="Пользователь запускает приложение"];
  "CUR-01" -> "CUR-02" [label="Сессия открыта"];
  "CUR-02" -> "CUR-03" [label="Пользователь редактирует входы"];
  "CUR-03" -> "CUR-05" [label="Пользователь готовит расчёт"];
  "CUR-05" -> "CUR-06" [label="Нужно создать сценарий"];
  "CUR-06" -> "CUR-05" [label="Сценарий сгенерирован"];
  "CUR-05" -> "CUR-07" [label="Пользователь запускает baseline"];
  "CUR-02" -> "CUR-08" [label="Пользователь видит блок оптимизации на главном экране"];
  "CUR-02" -> "CUR-09" [label="Пользователь идёт на инженерную страницу Optimization"];
  "CUR-08" -> "CUR-10" [label="Запуск StageRunner"];
  "CUR-09" -> "CUR-10" [label="Запуск StageRunner с инженерной страницы"];
  "CUR-09" -> "CUR-11" [label="Запуск distributed coordinator"];
  "CUR-10" -> "CUR-12" [label="Идёт staged optimisation"];
  "CUR-11" -> "CUR-12" [label="Идёт distributed optimisation"];
  "CUR-12" -> "CUR-13" [label="Пользователь открывает результаты"];
  "CUR-13" -> "CUR-14" [label="Пользователь хочет пространственно увидеть результат"];
  "CUR-02" -> "CUR-15" [label="Пользователь пытается собрать диагностику"];
  "CUR-02" -> "CUR-16" [label="Пользователь ищет пропавшую функцию"];
  "CUR-13" -> "CUR-17" [label="Пользователь интерпретирует результат"];
  "CUR-17" -> "CUR-03" [label="Пользователь исправляет входы"];
}
